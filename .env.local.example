# Repair Ninja Bastille — Variables d'environnement
# Copier en .env.local et remplir les valeurs

# Email (Resend recommandé — gratuit jusqu'à 3000 emails/mois)
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=rdv@repairninja.fr
EMAIL_TO=contact@repairninja.fr

# Site URL (production)
NEXT_PUBLIC_SITE_URL=https://www.repairninja.fr

# Google Analytics 4 (optionnel)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console verification
NEXT_PUBLIC_GSC_VERIFICATION=VOTRE_CODE
